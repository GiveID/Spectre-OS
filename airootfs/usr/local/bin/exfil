#!/usr/bin/env bash
# Spectre OS - Exfiltration preparation menu
# Compress, encrypt, and split files for secure transfer

set -euo pipefail

RED='\033[0;31m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
NC='\033[0m'

encrypt_split() {
    local file="$1"
    local chunk_mb="${2:-10}"
    [[ -f "$file" ]] || { echo "File not found."; return 1; }
    local base=$(basename "$file")
    local dir=$(dirname "$file")
    echo "[*] Compressing..."
    gzip -c "$file" > "${file}.gz"
    echo "[*] Encrypting with GPG..."
    gpg -c -o "${file}.gz.gpg" "${file}.gz"
    echo "[*] Splitting into ${chunk_mb}MB chunks..."
    split -b "${chunk_mb}M" "${file}.gz.gpg" "${dir}/${base}.part."
    rm -f "${file}.gz" "${file}.gz.gpg"
    echo "[+] Output: ${dir}/${base}.part.*"
    echo "    Reassemble: cat ${base}.part.* | gpg -d | gunzip > restored"
}

encrypt_age() {
    local file="$1"
    [[ -f "$file" ]] || { echo "File not found."; return 1; }
    echo "[*] Encrypting with age..."
    age -e -o "${file}.age" "$file" 2>/dev/null || {
        echo "[!] age requires a recipient. Run: age-keygen -o key.txt"
        echo "    Then: age -e -r \$(age-keygen -y key.txt) -o out.age $file"
        return 1
    }
    echo "[+] Output: ${file}.age"
}

menu() {
    echo ""
    echo -e "${CYAN}=== Spectre Exfil Menu ===${NC}"
    echo "1) Compress + GPG encrypt + split (default 10MB chunks)"
    echo "2) Compress + GPG encrypt + split (custom chunk size)"
    echo "3) Encrypt with age (modern, simple)"
    echo "4) Compress only (gzip)"
    echo "5) Exit"
    echo ""
    read -rp "Choice [1-5]: " choice

    case "$choice" in
        1)
            read -rp "File path: " f
            encrypt_split "$f" 10
            ;;
        2)
            read -rp "File path: " f
            read -rp "Chunk size (MB): " mb
            encrypt_split "$f" "${mb:-10}"
            ;;
        3)
            read -rp "File path: " f
            encrypt_age "$f"
            ;;
        4)
            read -rp "File path: " f
            [[ -f "$f" ]] && gzip -k "$f" && echo "[+] ${f}.gz" || echo "File not found."
            ;;
        5) exit 0 ;;
        *) echo "Invalid." ;;
    esac
}

menu
