#!/usr/bin/env bash
# Spectre OS - OPSEC checklist audit
# Checks: DNS leaks, open ports, running services, VPN/Tor status, browser fingerprint URL

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

echo ""
echo -e "${CYAN}=== Spectre OS OPSEC Checklist ===${NC}"
echo ""

# DNS leak
echo -e "${CYAN}[1] DNS Configuration${NC}"
if pgrep -x dnscrypt-proxy &>/dev/null; then
    echo -e "  ${GREEN}+${NC} dnscrypt-proxy running"
else
    echo -e "  ${YELLOW}!${NC} dnscrypt-proxy not running"
fi
echo "  Test: curl https://dnsleaktest.com"
echo ""

# Open ports
echo -e "${CYAN}[2] Listening Ports${NC}"
ss -tuln 2>/dev/null | grep LISTEN | while read -r line; do
    echo "  $line"
done
echo ""

# Running services
echo -e "${CYAN}[3] Notable Services${NC}"
for svc in tor nmbd smbd cups avahi-daemon; do
    if systemctl is-active --quiet "$svc" 2>/dev/null; then
        echo -e "  ${YELLOW}!${NC} $svc: RUNNING"
    fi
done
echo ""

# VPN/Tor status
echo -e "${CYAN}[4] Anonymity Status${NC}"
if systemctl is-active --quiet tor 2>/dev/null; then
    echo -e "  ${GREEN}+${NC} Tor: ACTIVE"
else
    echo -e "  ${RED}-${NC} Tor: INACTIVE"
fi
if ip route | grep -q tun; then
    echo -e "  ${GREEN}+${NC} VPN tunnel detected"
else
    echo -e "  ${YELLOW}!${NC} No VPN tunnel detected"
fi
echo ""

# Browser fingerprint
echo -e "${CYAN}[5] Browser Fingerprint Test${NC}"
echo "  URL: https://coveryourtracks.eff.org"
echo "  URL: https://browserleaks.com"
echo ""

echo -e "${CYAN}=== End Checklist ===${NC}"
echo ""
