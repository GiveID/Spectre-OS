#!/usr/bin/env bash
# Spectre OS - Toggle anonymity: Tor routing + MAC randomization
# Usage: anon [on|off|status]

set -euo pipefail

TOR_SOCKS="127.0.0.1:9050"

anon_on() {
    echo "[*] Enabling Tor routing..."
    export TORSOCKS_CONF_FILE=/etc/torsocks.conf 2>/dev/null
    for iface in /sys/class/net/*/; do
        i=$(basename "$iface")
        [[ "$i" == "lo" ]] && continue
        macchanger -r "$i" 2>/dev/null && echo "  MAC randomized: $i" || true
    done
    systemctl start tor 2>/dev/null || true
    echo "[+] Route traffic with: torsocks <command> or proxychains4 <command>"
}

anon_off() {
    echo "[*] Disabling Tor (MAC unchanged until reboot)..."
    systemctl stop tor 2>/dev/null || true
    echo "[+] Tor stopped. MAC will reset on next boot or run: macchanger -p <iface>"
}

anon_status() {
    if systemctl is-active --quiet tor 2>/dev/null; then
        echo "[+] Tor: ACTIVE"
    else
        echo "[-] Tor: INACTIVE"
    fi
    echo "Interfaces:"
    ip link show | grep -E '^[0-9]+:' | awk -F: '{print $2}' | tr -d ' ' | while read -r i; do
        [[ "$i" == "lo" ]] && continue
        mac=$(cat /sys/class/net/"$i"/address 2>/dev/null)
        echo "  $i: $mac"
    done
}

case "${1:-status}" in
    on) anon_on ;;
    off) anon_off ;;
    status) anon_status ;;
    *) echo "Usage: anon {on|off|status}"; exit 1 ;;
esac
