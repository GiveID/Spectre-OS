#!/usr/bin/env bash
# Spectre OS - Launch recon tmux session with amass, subfinder, httpx panes
# Requires: amass, subfinder, httpx (install via spectre-tools-install)

set -euo pipefail

SESSION="recon"
TARGET="${1:-}"

if [[ -z "$TARGET" ]]; then
    echo "Usage: recon <domain>"
    echo "Example: recon example.com"
    exit 1
fi

if ! command -v tmux &>/dev/null; then
    echo "[!] tmux not found. Install: pacman -S tmux"
    exit 1
fi

# Kill existing session
tmux kill-session -t "$SESSION" 2>/dev/null || true

# Create session with first pane
tmux new-session -d -s "$SESSION" -n "recon"
tmux send-keys -t "$SESSION" "echo 'Recon session for $TARGET'; echo 'Amass: amass enum -d $TARGET'; echo 'Subfinder: subfinder -d $TARGET'; echo 'Httpx: cat subs.txt | httpx'" C-m

# Split horizontally
tmux split-window -h -t "$SESSION"
tmux select-pane -t 0
tmux split-window -v -t "$SESSION"
tmux select-pane -t 2
tmux split-window -v -t "$SESSION"

# Pane 0: amass
tmux select-pane -t 0
tmux send-keys -t "$SESSION" "amass enum -passive -d $TARGET 2>/dev/null | tee -a amass_$TARGET.txt || echo 'amass not installed'" C-m

# Pane 1: subfinder
tmux select-pane -t 1
tmux send-keys -t "$SESSION" "subfinder -d $TARGET -silent 2>/dev/null | tee -a subfinder_$TARGET.txt || echo 'subfinder not installed'" C-m

# Pane 2: httpx placeholder
tmux select-pane -t 2
tmux send-keys -t "$SESSION" "echo 'Combine amass + subfinder output, then: cat subs_$TARGET.txt | httpx -silent'; echo 'Or run: cat amass_$TARGET.txt subfinder_$TARGET.txt | sort -u > subs_$TARGET.txt'" C-m

# Pane 3: workspace
tmux select-pane -t 3
tmux send-keys -t "$SESSION" "cd $(pwd) && echo 'Workspace ready'" C-m

tmux select-pane -t 0
tmux attach-session -t "$SESSION"
